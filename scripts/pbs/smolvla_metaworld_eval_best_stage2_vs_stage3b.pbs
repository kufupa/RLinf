#!/bin/bash
#PBS -N smolvla-eval-best-s2-s3b
#PBS -q v1_gpu72
#PBS -l select=1:ncpus=16:mem=96gb:ngpus=1:gpu_type=RTX6000:Qlist=v1_gpu72
#PBS -l walltime=06:00:00
#PBS -j oe
#PBS -o logs/pbs/smolvla-eval-best-s2-s3b.out

set -euo pipefail

# shellcheck source=scripts/pbs/smolvla_metaworld_common.sh
source "/rds/general/user/aa6622/home/project/RLinf/scripts/pbs/smolvla_metaworld_common.sh"
setup_smolvla_metaworld_env

RUN_ID="${PBS_JOBID:-local}"
RUN_LOG="logs/pbs/smolvla-eval-best-s2-s3b-${RUN_ID}.driver.log"
OUT_ROOT="${RLINF_RESULTS_DIR}/smolvla_eval_best_s2_s3b_${RUN_ID}"

S2_CKPTS="/rds/general/ephemeral/user/aa6622/ephemeral/rlinf_ray_runs/2835191/results/smolvla_direct_stage2_sparse_2835191.pbs-7/checkpoints"
S3B_CKPTS="/rds/general/ephemeral/user/aa6622/ephemeral/rlinf_ray_runs/2836701/results/smolvla_direct_stage3b_sparse_lr3e7_2836701.pbs-7/checkpoints"

{
  echo "wide_eval: stage2_sparse update25"
  "${PYTHON_BIN}" scripts/eval_smolvla_metaworld_ckpt_sweep.py \
    --run-name "wide_stage2_sparse_${RUN_ID}" \
    --checkpoint-dir "${S2_CKPTS}" \
    --output-dir "${OUT_ROOT}/stage2_sparse" \
    --num-envs 100 \
    --seed-base "${SMOLVLA_EVAL_SEED_BASE:-50000}" \
    --include-baseline \
    --only-updates "25"

  echo "wide_eval: stage3b_lr3e7 update50"
  "${PYTHON_BIN}" scripts/eval_smolvla_metaworld_ckpt_sweep.py \
    --run-name "wide_stage3b_lr3e7_${RUN_ID}" \
    --checkpoint-dir "${S3B_CKPTS}" \
    --output-dir "${OUT_ROOT}/stage3b_lr3e7" \
    --num-envs 100 \
    --seed-base "${SMOLVLA_EVAL_SEED_BASE:-50000}" \
    --include-baseline \
    --only-updates "50"
} 2>&1 | tee "${RUN_LOG}"
